{
  "name": "@rong/admin-ui",
  "version": "0.5.0",
  "description": "Rong Admin UI Framework - Reusable admin framework with standardized contracts",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./app-core": {
      "types": "./dist/app-core/index.d.ts",
      "import": "./dist/app-core/index.js"
    },
    "./app-plugin": {
      "types": "./dist/app-plugin/index.d.ts",
      "import": "./dist/app-plugin/index.js"
    },
    "./app-layout": {
      "types": "./dist/app-layout/index.d.ts",
      "import": "./dist/app-layout/index.js"
    },
    "./app-router": {
      "types": "./dist/app-router/index.d.ts",
      "import": "./dist/app-router/index.js"
    },
    "./app-permission": {
      "types": "./dist/app-permission/index.d.ts",
      "import": "./dist/app-permission/index.js"
    },
    "./app-request": {
      "types": "./dist/app-request/index.d.ts",
      "import": "./dist/app-request/index.js"
    },
    "./app-auth": {
      "types": "./dist/app-auth/index.d.ts",
      "import": "./dist/app-auth/index.js"
    },
    "./app-config": {
      "types": "./dist/app-config/index.d.ts",
      "import": "./dist/app-config/index.js"
    },
    "./app-preset": {
      "types": "./dist/app-preset/index.d.ts",
      "import": "./dist/app-preset/index.js"
    },
    "./theme": {
      "types": "./dist/theme/index.d.ts",
      "import": "./dist/theme/index.js"
    },
    "./components/*": {
      "types": "./dist/components/*/index.d.ts",
      "import": "./dist/components/*/index.js"
    },
    "./style.css": "./dist/admin-ui.css",
    "./dist/admin-ui.css": "./dist/admin-ui.css"
  },
  "style": "./dist/admin-ui.css",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint src --ext .ts,.vue --max-warnings 0",
    "lint:fix": "eslint src --ext .ts,.vue --fix",
    "format": "prettier --write \"src/**/*.{ts,vue,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,vue,json}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run tests/integration",
    "test:changed": "node scripts/test-changed.mjs",
    "gate:contract": "node scripts/gate-contract-parity.mjs",
    "gate:api": "node scripts/gate-api.mjs",
    "gate:changeset": "node scripts/gate-changeset.mjs",
    "gate:release": "node scripts/gate-release.mjs",
    "api:extract": "api-extractor run --local --verbose",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish",
    "quality-gate": "bash scripts/quality-gate.sh",
    "quality-gate:local": "bash scripts/ci/run-local.sh",
    "quality-gate:ci": "bash scripts/ci/run-ci.sh",
    "knowledge:new": "node scripts/knowledge/new-iteration.mjs",
    "prepublishOnly": "npm run build",
    "pack:dry": "npm pack --dry-run"
  },
  "dependencies": {
    "lucide-vue-next": "^0.577.0",
    "pinia": ">=2.0.0",
    "vue": ">=3.4.0",
    "vue-router": ">=4.0.0"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@microsoft/api-documenter": "^7.29.6",
    "@microsoft/api-extractor": "^7.57.6",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vitest/coverage-v8": "^2.1.9",
    "@vue/test-utils": "^2.4.0",
    "axe-core": "^4.11.1",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-vue": "^9.0.0",
    "happy-dom": "^15.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^2.0.0",
    "vitest-axe": "^0.1.0",
    "vue-tsc": "^2.0.0"
  },
  "peerDependencies": {
    "naive-ui": ">=2.38.0",
    "pinia": ">=2.0.0",
    "vue": ">=3.4.0",
    "vue-router": ">=4.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT"
}
